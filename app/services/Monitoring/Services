<?php

namespace App\Services\Custom;

/**
 * Custom Authentication Service - APS Dream Home
 * Custom MVC implementation without Laravel dependencies
 * Following APS Dream Home custom architecture patterns
 */
class AuthenticationService
{
    private $database;
    private $logger;
    private $config;
    private $session;
    
    // Authentication constants
    const STATUS_ACTIVE = 'active';
    const STATUS_INACTIVE = 'inactive';
    const STATUS_SUSPENDED = 'suspended';
    const STATUS_LOCKED = 'locked';
    
    // Role constants
    const ROLE_ADMIN = 'admin';
    const ROLE_MANAGER = 'manager';
    const ROLE_ASSOCIATE = 'associate';
    const ROLE_USER = 'user';
    
    // Security settings
    private $maxLoginAttempts = 5;
    private $lockoutDuration = 900; // 15 minutes
    private $sessionTimeout = 3600; // 1 hour
    private $passwordMinLength = 8;
    
    public function __construct()
    {
        $this->database = \App\Core\Database::getInstance();
        $this->logger = new \App\Core\Logger();
        $this->config = \App\Core\Config::getInstance();
        $this->session = new \App\Core\Session();
        
        // Load configuration
        $this->maxLoginAttempts = $this->config->get('auth.max_login_attempts', 5);
        $this->lockoutDuration = $this->config->get('auth.lockout_duration', 900);
        $this->sessionTimeout = $this->config->get('auth.session_timeout', 3600);
        $this->passwordMinLength = $this->config->get('auth.password_min_length', 8);
    }
    
    /**
     * Authenticate user login
     */
    public function login($email, $password, $remember = false)
    {
        try {
            // Validate input
            if (!$this->validateEmail($email)) {
                return [
                    'success' => false,
                    'message' => 'Invalid email format',
                    'code' => 'INVALID_EMAIL'
                ];
            }
            
            if (empty($password)) {
                return [
                    'success' => false,
                    'message' => 'Password is required',
                    'code' => 'PASSWORD_REQUIRED'
                ];
            }
            
            // Check rate limiting
            if (!$this->checkRateLimit($email)) {
                return [
                    'success' => false,
                    'message' => 'Too many login attempts. Please try again later.',
                    'code' => 'RATE_LIMITED',
                    'locked' => true
                ];
            }
            
            // Get user from database
            $user = $this->getUserByEmail($email);
            if (!$user) {
                $this->recordFailedLogin($email, 'USER_NOT_FOUND');
                return [
                    'success' => false,
                    'message' => 'Invalid credentials',
                    'code' => 'INVALID_CREDENTIALS'
                ];
            }
            
            // Check user status
            if ($user['status'] !== self::STATUS_ACTIVE) {
                return [
                    'success' => false,
                    'message' => 'Account is ' . $user['status'],
                    'code' => 'ACCOUNT_INACTIVE'
                ];
            }
            
            // Verify password
            if (!$this->verifyPassword($password, $user['password'])) {
                $this->recordFailedLogin($email, 'INVALID_PASSWORD', $user['id']);
                return [
                    'success' => false,
                    'message' => 'Invalid credentials',
                    'code' => 'INVALID_CREDENTIALS'
                ];
            }
            
            // Check if account is locked
            if ($this->isAccountLocked($user['id'])) {
                return [
                    'success' => false,
                    'message' => 'Account is temporarily locked',
                    'code' => 'ACCOUNT_LOCKED'
                ];
            }
            
            // Successful login
            $this->recordSuccessfulLogin($user['id'], $email);
            $this->createUserSession($user, $remember);
            
            // Update last login
            $this->updateLastLogin($user['id']);
            
            $this->logger->info('User logged in successfully', [
                'user_id' => $user['id'],
                'email' => $email,
                'ip' => $this->getClientIp(),
                'user_agent' => $_SERVER['HTTP_USER_AGENT'] ?? 'Unknown'
            ]);
            
            return [
                'success' => true,
                'message' => 'Login successful',
                'user' => $this->sanitizeUserData($user),
                'redirect' => $this->getRedirectUrl($user['role'])
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Login error', [
                'email' => $email,
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString()
            ]);
            
            return [
                'success' => false,
                'message' => 'Login failed due to system error',
                'code' => 'SYSTEM_ERROR'
            ];
        }
    }
    
    /**
     * Logout user
     */
    public function logout()
    {
        try {
            $userId = $this->session->get('user_id');
            
            if ($userId) {
                // Record logout
                $this->recordLogout($userId);
                
                $this->logger->info('User logged out', [
                    'user_id' => $userId,
                    'ip' => $this->getClientIp()
                ]);
            }
            
            // Destroy session
            $this->session->destroy();
            
            // Clear remember me cookie if exists
            if (isset($_COOKIE['remember_token'])) {
                setcookie('remember_token', '', time() - 3600, '/');
                $this->clearRememberToken($userId);
            }
            
            return [
                'success' => true,
                'message' => 'Logout successful'
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Logout error', [
                'error' => $e->getMessage()
            ]);
            
            return [
                'success' => false,
                'message' => 'Logout failed'
            ];
        }
    }
    
    /**
     * Check if user is authenticated
     */
    public function isAuthenticated()
    {
        $userId = $this->session->get('user_id');
        
        if (!$userId) {
            // Check remember me token
            $rememberToken = $_COOKIE['remember_token'] ?? null;
            if ($rememberToken) {
                return $this->authenticateWithRememberToken($rememberToken);
            }
            
            return false;
        }
        
        // Check session validity
        return $this->isSessionValid($userId);
    }
    
    /**
     * Get current authenticated user
     */
    public function getCurrentUser()
    {
        if (!$this->isAuthenticated()) {
            return null;
        }
        
        $userId = $this->session->get('user_id');
        return $this->getUserById($userId);
    }
    
    /**
     * Get user role
     */
    public function getUserRole()
    {
        $user = $this->getCurrentUser();
        return $user ? $user['role'] : null;
    }
    
    /**
     * Check if user has permission
     */
    public function hasPermission($permission)
    {
        $user = $this->getCurrentUser();
        
        if (!$user) {
            return false;
        }
        
        // Admin has all permissions
        if ($user['role'] === self::ROLE_ADMIN) {
            return true;
        }
        
        // Check role-based permissions
        $rolePermissions = $this->getRolePermissions($user['role']);
        return in_array($permission, $rolePermissions);
    }
    
    /**
     * Register new user
     */
    public function register($userData)
    {
        try {
            // Validate required fields
            $requiredFields = ['name', 'email', 'password', 'role'];
            foreach ($requiredFields as $field) {
                if (empty($userData[$field])) {
                    return [
                        'success' => false,
                        'message' => ucfirst($field) . ' is required',
                        'code' => 'MISSING_FIELD'
                    ];
                }
            }
            
            // Validate email
            if (!$this->validateEmail($userData['email'])) {
                return [
                    'success' => false,
                    'message' => 'Invalid email format',
                    'code' => 'INVALID_EMAIL'
                ];
            }
            
            // Check if email already exists
            if ($this->getUserByEmail($userData['email'])) {
                return [
                    'success' => false,
                    'message' => 'Email already exists',
                    'code' => 'EMAIL_EXISTS'
                ];
            }
            
            // Validate password
            if (strlen($userData['password']) < $this->passwordMinLength) {
                return [
                    'success' => false,
                    'message' => 'Password must be at least ' . $this->passwordMinLength . ' characters',
                    'code' => 'PASSWORD_TOO_SHORT'
                ];
            }
            
            // Validate role
            if (!in_array($userData['role'], $this->getValidRoles())) {
                return [
                    'success' => false,
                    'message' => 'Invalid role',
                    'code' => 'INVALID_ROLE'
                ];
            }
            
            // Hash password
            $hashedPassword = $this->hashPassword($userData['password']);
            
            // Prepare user data
            $user = [
                'name' => $userData['name'],
                'email' => $userData['email'],
                'password' => $hashedPassword,
                'role' => $userData['role'],
                'status' => self::STATUS_ACTIVE,
                'created_at' => date('Y-m-d H:i:s'),
                'updated_at' => date('Y-m-d H:i:s')
            ];
            
            // Insert user into database
            $userId = $this->database->insert('users', $user);
            
            if (!$userId) {
                return [
                    'success' => false,
                    'message' => 'Failed to create user',
                    'code' => 'DATABASE_ERROR'
                ];
            }
            
            $user['id'] = $userId;
            
            $this->logger->info('User registered successfully', [
                'user_id' => $userId,
                'email' => $userData['email'],
                'role' => $userData['role'],
                'ip' => $this->getClientIp()
            ]);
            
            return [
                'success' => true,
                'message' => 'User registered successfully',
                'user' => $this->sanitizeUserData($user)
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Registration error', [
                'email' => $userData['email'] ?? 'unknown',
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString()
            ]);
            
            return [
                'success' => false,
                'message' => 'Registration failed due to system error',
                'code' => 'SYSTEM_ERROR'
            ];
        }
    }
    
    /**
     * Change password
     */
    public function changePassword($userId, $currentPassword, $newPassword)
    {
        try {
            // Get user
            $user = $this->getUserById($userId);
            if (!$user) {
                return [
                    'success' => false,
                    'message' => 'User not found',
                    'code' => 'USER_NOT_FOUND'
                ];
            }
            
            // Verify current password
            if (!$this->verifyPassword($currentPassword, $user['password'])) {
                return [
                    'success' => false,
                    'message' => 'Current password is incorrect',
                    'code' => 'INVALID_CURRENT_PASSWORD'
                ];
            }
            
            // Validate new password
            if (strlen($newPassword) < $this->passwordMinLength) {
                return [
                    'success' => false,
                    'message' => 'Password must be at least ' . $this->passwordMinLength . ' characters',
                    'code' => 'PASSWORD_TOO_SHORT'
                ];
            }
            
            // Hash new password
            $hashedPassword = $this->hashPassword($newPassword);
            
            // Update password
            $updated = $this->database->update('users', 
                ['password' => $hashedPassword, 'updated_at' => date('Y-m-d H:i:s')], 
                'id = ?', 
                [$userId]
            );
            
            if (!$updated) {
                return [
                    'success' => false,
                    'message' => 'Failed to update password',
                    'code' => 'DATABASE_ERROR'
                ];
            }
            
            // Clear all sessions for this user
            $this->clearUserSessions($userId);
            
            $this->logger->info('Password changed successfully', [
                'user_id' => $userId,
                'ip' => $this->getClientIp()
            ]);
            
            return [
                'success' => true,
                'message' => 'Password changed successfully'
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Password change error', [
                'user_id' => $userId,
                'error' => $e->getMessage()
            ]);
            
            return [
                'success' => false,
                'message' => 'Password change failed',
                'code' => 'SYSTEM_ERROR'
            ];
        }
    }
    
    /**
     * Reset password
     */
    public function resetPassword($email)
    {
        try {
            // Get user
            $user = $this->getUserByEmail($email);
            if (!$user) {
                return [
                    'success' => false,
                    'message' => 'Email not found',
                    'code' => 'EMAIL_NOT_FOUND'
                ];
            }
            
            // Generate reset token
            $resetToken = $this->generateRandomToken();
            $resetTokenExpiry = date('Y-m-d H:i:s', time() + 3600); // 1 hour
            
            // Update user with reset token
            $updated = $this->database->update('users', 
                [
                    'reset_token' => $resetToken,
                    'reset_token_expiry' => $resetTokenExpiry,
                    'updated_at' => date('Y-m-d H:i:s')
                ], 
                'id = ?', 
                [$user['id']]
            );
            
            if (!$updated) {
                return [
                    'success' => false,
                    'message' => 'Failed to generate reset token',
                    'code' => 'DATABASE_ERROR'
                ];
            }
            
            // Send reset email (implementation depends on email service)
            $resetUrl = $this->config->get('app.url') . '/reset-password?token=' . $resetToken;
            $this->sendPasswordResetEmail($email, $resetUrl);
            
            $this->logger->info('Password reset requested', [
                'user_id' => $user['id'],
                'email' => $email,
                'ip' => $this->getClientIp()
            ]);
            
            return [
                'success' => true,
                'message' => 'Password reset link sent to your email'
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Password reset error', [
                'email' => $email,
                'error' => $e->getMessage()
            ]);
            
            return [
                'success' => false,
                'message' => 'Password reset failed',
                'code' => 'SYSTEM_ERROR'
            ];
        }
    }
    
    // Private helper methods
    
    private function validateEmail($email)
    {
        return filter_var($email, FILTER_VALIDATE_EMAIL) !== false;
    }
    
    private function checkRateLimit($email)
    {
        $cacheKey = 'login_attempts_' . md5($email);
        $attempts = $this->session->get($cacheKey, 0);
        
        if ($attempts >= $this->maxLoginAttempts) {
            $lastAttempt = $this->session->get($cacheKey . '_last', 0);
            if (time() - $lastAttempt < $this->lockoutDuration) {
                return false;
            }
            // Reset attempts after lockout period
            $this->session->set($cacheKey, 0);
        }
        
        return true;
    }
    
    private function recordFailedLogin($email, $reason, $userId = null)
    {
        $cacheKey = 'login_attempts_' . md5($email);
        $attempts = $this->session->get($cacheKey, 0) + 1;
        $this->session->set($cacheKey, $attempts);
        $this->session->set($cacheKey . '_last', time());
        
        // Record in database
        $this->database->insert('login_attempts', [
            'email' => $email,
            'user_id' => $userId,
            'ip_address' => $this->getClientIp(),
            'user_agent' => $_SERVER['HTTP_USER_AGENT'] ?? 'Unknown',
            'reason' => $reason,
            'created_at' => date('Y-m-d H:i:s')
        ]);
    }
    
    private function recordSuccessfulLogin($userId, $email)
    {
        // Clear failed attempts
        $cacheKey = 'login_attempts_' . md5($email);
        $this->session->delete($cacheKey);
        $this->session->delete($cacheKey . '_last');
        
        // Record in database
        $this->database->insert('login_logs', [
            'user_id' => $userId,
            'email' => $email,
            'ip_address' => $this->getClientIp(),
            'user_agent' => $_SERVER['HTTP_USER_AGENT'] ?? 'Unknown',
            'status' => 'success',
            'created_at' => date('Y-m-d H:i:s')
        ]);
    }
    
    private function createUserSession($user, $remember = false)
    {
        $this->session->regenerate();
        $this->session->set('user_id', $user['id']);
        $this->session->set('user_email', $user['email']);
        $this->session->set('user_role', $user['role']);
        $this->session->set('user_name', $user['name']);
        $this->session->set('logged_in_at', time());
        
        if ($remember) {
            $rememberToken = $this->generateRandomToken();
            $this->session->set('remember_token', $rememberToken);
            
            // Store remember token in database
            $this->database->update('users', 
                ['remember_token' => $rememberToken], 
                'id = ?', 
                [$user['id']]
            );
            
            // Set cookie
            setcookie('remember_token', $rememberToken, time() + (30 * 24 * 60 * 60), '/'); // 30 days
        }
    }
    
    private function isSessionValid($userId)
    {
        $loggedInAt = $this->session->get('logged_in_at', 0);
        return (time() - $loggedInAt) < $this->sessionTimeout;
    }
    
    private function authenticateWithRememberToken($token)
    {
        $user = $this->getUserByRememberToken($token);
        if (!$user) {
            return false;
        }
        
        $this->createUserSession($user, true);
        return true;
    }
    
    private function getUserByEmail($email)
    {
        return $this->database->selectOne("SELECT * FROM users WHERE email = ? AND deleted_at IS NULL", [$email]);
    }
    
    private function getUserById($id)
    {
        return $this->database->selectOne("SELECT * FROM users WHERE id = ? AND deleted_at IS NULL", [$id]);
    }
    
    private function getUserByRememberToken($token)
    {
        return $this->database->selectOne("SELECT * FROM users WHERE remember_token = ? AND deleted_at IS NULL", [$token]);
    }
    
    private function updateLastLogin($userId)
    {
        $this->database->update('users', 
            ['last_login_at' => date('Y-m-d H:i:s'), 'updated_at' => date('Y-m-d H:i:s')], 
            'id = ?', 
            [$userId]
        );
    }
    
    private function sanitizeUserData($user)
    {
        unset($user['password'], $user['remember_token'], $user['reset_token'], $user['reset_token_expiry']);
        return $user;
    }
    
    private function getRedirectUrl($role)
    {
        $redirects = [
            self::ROLE_ADMIN => '/admin/dashboard',
            self::ROLE_MANAGER => '/manager/dashboard',
            self::ROLE_ASSOCIATE => '/associate/dashboard',
            self::ROLE_USER => '/user/dashboard'
        ];
        
        return $redirects[$role] ?? '/dashboard';
    }
    
    private function getRolePermissions($role)
    {
        $permissions = [
            self::ROLE_ADMIN => ['*'], // All permissions
            self::ROLE_MANAGER => ['manage_users', 'view_reports', 'manage_content'],
            self::ROLE_ASSOCIATE => ['view_dashboard', 'manage_clients', 'view_reports'],
            self::ROLE_USER => ['view_profile', 'edit_profile']
        ];
        
        return $permissions[$role] ?? [];
    }
    
    private function getValidRoles()
    {
        return [self::ROLE_ADMIN, self::ROLE_MANAGER, self::ROLE_ASSOCIATE, self::ROLE_USER];
    }
    
    private function hashPassword($password)
    {
        return password_hash($password, PASSWORD_ARGON2ID, ['memory_cost' => 65536, 'time_cost' => 4, 'threads' => 3]);
    }
    
    private function verifyPassword($password, $hash)
    {
        return password_verify($password, $hash);
    }
    
    private function generateRandomToken($length = 32)
    {
        return bin2hex(random_bytes($length));
    }
    
    private function getClientIp()
    {
        $headers = ['HTTP_CF_CONNECTING_IP', 'HTTP_CLIENT_IP', 'HTTP_X_FORWARDED_FOR', 'REMOTE_ADDR'];
        
        foreach ($headers as $header) {
            if (!empty($_SERVER[$header])) {
                return $_SERVER[$header];
            }
        }
        
        return 'UNKNOWN';
    }
    
    private function recordLogout($userId)
    {
        $this->database->insert('login_logs', [
            'user_id' => $userId,
            'ip_address' => $this->getClientIp(),
            'user_agent' => $_SERVER['HTTP_USER_AGENT'] ?? 'Unknown',
            'status' => 'logout',
            'created_at' => date('Y-m-d H:i:s')
        ]);
    }
    
    private function clearRememberToken($userId)
    {
        $this->database->update('users', 
            ['remember_token' => null, 'updated_at' => date('Y-m-d H:i:s')], 
            'id = ?', 
            [$userId]
        );
    }
    
    private function clearUserSessions($userId)
    {
        // Implementation depends on session storage
        // This would clear all active sessions for the user
    }
    
    private function isAccountLocked($userId)
    {
        $attempts = $this->database->selectOne(
            "SELECT COUNT(*) as count FROM login_attempts WHERE user_id = ? AND created_at > DATE_SUB(NOW(), INTERVAL 1 HOUR)",
            [$userId]
        );
        
        return $attempts['count'] >= $this->maxLoginAttempts;
    }
    
    private function sendPasswordResetEmail($email, $resetUrl)
    {
        // Implementation depends on email service
        // This would send an email with the reset link
    }
}
