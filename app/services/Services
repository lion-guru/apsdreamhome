            ],
            'ar_SA' => [
                'name' => 'Arabic (Saudi Arabia)',
                'native_name' => 'العربية',
                'code' => 'ar',
                'direction' => 'rtl',
                'date_format' => 'Y/m/d',
                'time_format' => 'h:i A',
                'currency' => 'SAR',
                'decimal_separator' => '.',
                'thousands_separator' => ','
            ]
        ];
    }
    
    /**
     * Check if locale is supported
     */
    public function isLocaleSupported($locale)
    {
        return array_key_exists($locale, $this->supportedLocales);
    }
    
    /**
     * Get current locale
     */
    public function getCurrentLocale()
    {
        return $this->currentLocale;
    }
    
    /**
     * Set locale
     */
    public function setLocale($locale)
    {
        if ($this->isLocaleSupported($locale)) {
            $this->currentLocale = $locale;
            $this->session->set('locale', $locale);
            
            $this->logger->info('Locale changed', [
                'old_locale' => $this->session->get('locale'),
                'new_locale' => $locale
            ]);
            
            return true;
        }
        
        return false;
    }
    
    /**
     * Get translation for a key
     */
    public function translate($key, array $parameters = [], $locale = null)
    {
        $locale = $locale ?: $this->currentLocale;
        
        // Check cache first
        $cacheKey = "$locale.$key";
        if (isset($this->translationCache[$cacheKey])) {
            return $this->replaceParameters($this->translationCache[$cacheKey], $parameters);
        }
        
        // Get translation from database
        $translation = $this->getTranslationFromDatabase($key, $locale);
        
        // Fallback to English if not found
        if (!$translation && $locale !== 'en_US') {
            $translation = $this->getTranslationFromDatabase($key, 'en_US');
        }
        
        // Fallback to key if still not found
        if (!$translation) {
            $translation = $key;
        }
        
        // Cache the result
        $this->translationCache[$cacheKey] = $translation;
        
        return $this->replaceParameters($translation, $parameters);
    }
    
    /**
     * Get translation from database
     */
    private function getTranslationFromDatabase($key, $locale)
    {
        try {
            $result = $this->database->selectOne(
                "SELECT translation FROM translations 
                 WHERE locale_key = ? AND locale = ? AND status = 'active'",
                [$key, $locale]
            );
            
            return $result ? $result['translation'] : null;
            
        } catch (Exception $e) {
            $this->logger->error('Failed to get translation from database', [
                'key' => $key,
                'locale' => $locale,
                'error' => $e->getMessage()
            ]);
            
            return null;
        }
    }
    
    /**
     * Replace parameters in translation string
     */
    private function replaceParameters($translation, array $parameters)
    {
        if (empty($parameters)) {
            return $translation;
        }
        
        foreach ($parameters as $key => $value) {
            $translation = str_replace(":$key", $value, $translation);
        }
        
        return $translation;
    }
    
    /**
     * Get locale info
     */
    public function getLocaleInfo($locale = null)
    {
        $locale = $locale ?: $this->currentLocale;
        
        return $this->supportedLocales[$locale] ?? $this->supportedLocales[$this->defaultLocale];
    }
    
    /**
     * Get all supported locales
     */
    public function getSupportedLocales()
    {
        return $this->supportedLocales;
    }
    
    /**
     * Format date according to locale
     */
    public function formatDate($date, $format = null, $locale = null)
    {
        $localeInfo = $this->getLocaleInfo($locale);
        $dateFormat = $format ?: $localeInfo['date_format'];
        
        if (is_string($date)) {
            $date = new DateTime($date);
        } elseif (!$date instanceof DateTime) {
            $date = new DateTime();
        }
        
        return $date->format($dateFormat);
    }
    
    /**
     * Format time according to locale
     */
    public function formatTime($time, $format = null, $locale = null)
    {
        $localeInfo = $this->getLocaleInfo($locale);
        $timeFormat = $format ?: $localeInfo['time_format'];
        
        if (is_string($time)) {
            $time = new DateTime($time);
        } elseif (!$time instanceof DateTime) {
            $time = new DateTime();
        }
        
        return $time->format($timeFormat);
    }
    
    /**
     * Format datetime according to locale
     */
    public function formatDateTime($dateTime, $format = null, $locale = null)
    {
        $localeInfo = $this->getLocaleInfo($locale);
        $dateFormat = $format ?: $localeInfo['date_format'] . ' ' . $localeInfo['time_format'];
        
        if (is_string($dateTime)) {
            $dateTime = new DateTime($dateTime);
        } elseif (!$dateTime instanceof DateTime) {
            $dateTime = new DateTime();
        }
        
        return $dateTime->format($dateFormat);
    }
    
    /**
     * Format currency according to locale
     */
    public function formatCurrency($amount, $currency = null, $locale = null)
    {
        $localeInfo = $this->getLocaleInfo($locale);
        $currencyCode = $currency ?: $localeInfo['currency'];
        $decimalSeparator = $localeInfo['decimal_separator'];
        $thousandsSeparator = $localeInfo['thousands_separator'];
        
        // Format number
        $formattedAmount = number_format(
            $amount, 
            2, 
            $decimalSeparator, 
            $thousandsSeparator
        );
        
        return $formattedAmount . ' ' . $currencyCode;
    }
    
    /**
     * Format number according to locale
     */
    public function formatNumber($number, $decimals = 2, $locale = null)
    {
        $localeInfo = $this->getLocaleInfo($locale);
        $decimalSeparator = $localeInfo['decimal_separator'];
        $thousandsSeparator = $localeInfo['thousands_separator'];
        
        return number_format($number, $decimals, $decimalSeparator, $thousandsSeparator);
    }
    
    /**
     * Get text direction for locale
     */
    public function getTextDirection($locale = null)
    {
        $localeInfo = $this->getLocaleInfo($locale);
        return $localeInfo['direction'];
    }
    
    /**
     * Check if current locale is RTL
     */
    public function isRTL($locale = null)
    {
        return $this->getTextDirection($locale) === 'rtl';
    }
    
    /**
     * Add new translation
     */
    public function addTranslation($key, $translation, $locale = null, $category = 'general')
    {
        $targetLocale = $locale ?: $this->currentLocale;
        
        if (!$this->isLocaleSupported($targetLocale)) {
            return [
                'success' => false,
                'message' => 'Locale not supported'
            ];
        }
        
        try {
            // Check if translation exists
            $existing = $this->database->selectOne(
                "SELECT id FROM translations 
                 WHERE locale_key = ? AND locale = ?",
                [$key, $targetLocale]
            );
            
            if ($existing) {
                // Update existing translation
                $this->database->update(
                    'translations',
                    [
                        'translation' => $translation,
                        'category' => $category,
                        'updated_at' => date('Y-m-d H:i:s')
                    ],
                    'locale_key = ? AND locale = ?',
                    [$key, $targetLocale]
                );
                
                $action = 'updated';
            } else {
                // Insert new translation
                $this->database->insert('translations', [
                    'locale_key' => $key,
                    'locale' => $targetLocale,
                    'translation' => $translation,
                    'category' => $category,
                    'status' => 'active',
                    'created_at' => date('Y-m-d H:i:s'),
                    'updated_at' => date('Y-m-d H:i:s')
                ]);
                
                $action = 'created';
            }
            
            // Clear cache for this key
            $this->clearTranslationCache($key, $targetLocale);
            
            $this->logger->info("Translation $action", [
                'key' => $key,
                'locale' => $targetLocale,
                'category' => $category
            ]);
            
            return [
                'success' => true,
                'message' => "Translation $action successfully"
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Failed to add translation', [
                'key' => $key,
                'locale' => $targetLocale,
                'error' => $e->getMessage()
            ]);
            
            return [
                'success' => false,
                'message' => 'Failed to add translation'
            ];
        }
    }
    
    /**
     * Import translations from file
     */
    public function importTranslations($filePath, $locale, $format = 'json')
    {
        if (!file_exists($filePath)) {
            return [
                'success' => false,
                'message' => 'File not found'
            ];
        }
        
        try {
            $content = file_get_contents($filePath);
            $translations = $format === 'json' ? json_decode($content, true) : $this->parseIniFile($content);
            
            if (!$translations) {
                return [
                    'success' => false,
                    'message' => 'Invalid file format'
                ];
            }
            
            $imported = 0;
            $updated = 0;
            
            foreach ($translations as $key => $translation) {
                $result = $this->addTranslation($key, $translation, $locale);
                
                if ($result['success']) {
                    if (strpos($result['message'], 'updated') !== false) {
                        $updated++;
                    } else {
                        $imported++;
                    }
                }
            }
            
            $this->logger->info('Translations imported', [
                'file' => $filePath,
                'locale' => $locale,
                'imported' => $imported,
                'updated' => $updated
            ]);
            
            return [
                'success' => true,
                'message' => 'Import completed',
                'imported' => $imported,
                'updated' => $updated
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Failed to import translations', [
                'file' => $filePath,
                'locale' => $locale,
                'error' => $e->getMessage()
            ]);
            
            return [
                'success' => false,
                'message' => 'Import failed'
            ];
        }
    }
    
    /**
     * Export translations to file
     */
    public function exportTranslations($locale = null, $format = 'json')
    {
        $targetLocale = $locale ?: $this->currentLocale;
        
        try {
            $translations = $this->database->select(
                "SELECT locale_key, translation, category FROM translations 
                 WHERE locale = ? AND status = 'active'
                 ORDER BY category, locale_key",
                [$targetLocale]
            );
            
            if (empty($translations)) {
                return [
                    'success' => false,
                    'message' => 'No translations found'
                ];
            }
            
            // Group by category
            $groupedTranslations = [];
            foreach ($translations as $translation) {
                $groupedTranslations[$translation['category']][$translation['locale_key']] = $translation['translation'];
            }
            
            $content = $format === 'json' ? json_encode($groupedTranslations, JSON_PRETTY_PRINT) : $this->formatAsIni($groupedTranslations);
            
            $filename = "translations_{$targetLocale}." . $format;
            $filepath = STORAGE_PATH . "/exports/$filename";
            
            // Ensure export directory exists
            $exportDir = dirname($filepath);
            if (!is_dir($exportDir)) {
                mkdir($exportDir, 0755, true);
            }
            
            file_put_contents($filepath, $content);
            
            $this->logger->info('Translations exported', [
                'locale' => $targetLocale,
                'format' => $format,
                'file' => $filename
            ]);
            
            return [
                'success' => true,
                'message' => 'Export completed',
                'file' => $filename,
                'path' => $filepath
            ];
            
        } catch (Exception $e) {
            $this->logger->error('Failed to export translations', [
                'locale' => $targetLocale,
                'format' => $format,
                'error' => $e->getMessage()
            ]);
            
            return [
                'success' => false,
                'message' => 'Export failed'
            ];
        }
    }
    
    /**
     * Clear translation cache
     */
    private function clearTranslationCache($key = null, $locale = null)
    {
        if ($key && $locale) {
            unset($this->translationCache["$locale.$key"]);
        } elseif ($key) {
            // Clear all entries for this key across all locales
            foreach ($this->translationCache as $cacheKey => $value) {
                if (strpos($cacheKey, ".$key") !== false) {
                    unset($this->translationCache[$cacheKey]);
                }
            }
        } else {
            // Clear all cache
            $this->translationCache = [];
        }
    }
    
    /**
     * Parse INI file format
     */
    private function parseIniFile($content)
    {
        $translations = [];
        $lines = explode("\n", $content);
        
        foreach ($lines as $line) {
            $line = trim($line);
            if (empty($line) || strpos($line, ';') === 0) {
                continue;
            }
            
            if (strpos($line, '=') !== false) {
                list($key, $value) = explode('=', $line, 2);
                $translations[trim($key)] = trim($value, '"');
            }
        }
        
        return $translations;
    }
    
    /**
     * Format as INI file
     */
    private function formatAsIni($translations)
    {
        $content = "; Translations Export - " . date('Y-m-d H:i:s') . "\n\n";
        
        foreach ($translations as $category => $items) {
            $content .= "[$category]\n";
            
            foreach ($items as $key => $value) {
                $content .= "$key = \"$value\"\n";
            }
            
            $content .= "\n";
        }
        
        return $content;
    }
    
    /**
     * Get translation statistics
     */
    public function getTranslationStats()
    {
        try {
            $stats = [];
            
            foreach ($this->supportedLocales as $locale => $info) {
                $count = $this->database->selectOne(
                    "SELECT COUNT(*) as count FROM translations 
                     WHERE locale = ? AND status = 'active'",
                    [$locale]
                );
                
                $stats[$locale] = [
                    'locale' => $locale,
                    'name' => $info['name'],
                    'native_name' => $info['native_name'],
                    'translations_count' => $count ? $count['count'] : 0
                ];
            }
            
            return $stats;
            
        } catch (Exception $e) {
            $this->logger->error('Failed to get translation stats', [
                'error' => $e->getMessage()
            ]);
            
            return [];
        }
    }
}
