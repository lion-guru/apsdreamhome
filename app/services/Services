                'currency' => 'USD',
                'decimal_separator' => '.',
                'thousands_separator' => ','
            ],
            'hi_IN' => [
                'name' => 'Hindi (India)',
                'native_name' => 'हिंदी',
                'code' => 'hi',
                'direction' => 'ltr',
                'date_format' => 'd-m-Y',
                'time_format' => 'g:i A',
                'currency' => 'INR',
                'decimal_separator' => '.',
                'thousands_separator' => ','
            ],
            'es_ES' => [
                'name' => 'Spanish (Spain)',
                'native_name' => 'Español',
                'code' => 'es',
                'direction' => 'ltr',
                'date_format' => 'd/m/Y',
                'time_format' => 'H:i:s',
                'currency' => 'EUR',
                'decimal_separator' => ',',
                'thousands_separator' => '.'
            ],
            'fr_FR' => [
                'name' => 'French (France)',
                'native_name' => 'Français',
                'code' => 'fr',
                'direction' => 'ltr',
                'date_format' => 'd/m/Y',
                'time_format' => 'H:i:s',
                'currency' => 'EUR',
                'decimal_separator' => ',',
