# APS Dream Home - Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME="APS Dream Home"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://apsdreamhome.com
BASE_URL=https://apsdreamhome.com

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=apsdreamhome
DB_USERNAME=your_db_username
DB_PASSWORD=your_strong_password

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP Example)
# ============================================
# For Gmail: Generate App Password at https://myaccount.google.com/apppasswords
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@apsdreamhome.com
MAIL_FROM_NAME="APS Dream Home"

# Admin notification email
ADMIN_EMAIL=admin@apsdreamhome.com

# ============================================
# SMS CONFIGURATION (MSG91)
# ============================================
# Get API Key from: https://msg91.com/
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=APSDHM
MSG91_TEMPLATE_ID=your_template_id_here

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================
# Get keys from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Test Mode (set to true for testing)
RAZORPAY_TEST_MODE=false

# ============================================
# SECURITY SETTINGS
# ============================================
# Generate random string: openssl rand -base64 32
CSRF_TOKEN_SALT=change_this_to_random_string_32_chars

# Session Settings
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ============================================
# PERFORMANCE SETTINGS
# ============================================
CACHE_DRIVER=file
CACHE_LIFETIME=3600
CACHE_PATH=/var/www/apsdreamhome/storage/cache

# Enable OPcache for production
OPCACHE_ENABLE=true
OPCACHE_MEMORY_CONSUMPTION=256
OPCACHE_MAX_ACCELERATED_FILES=10000

# ============================================
# UPLOAD SETTINGS
# ============================================
MAX_UPLOAD_SIZE=10M
MAX_FILE_UPLOADS=20
UPLOAD_PATH=/var/www/apsdreamhome/public/uploads

# Allowed image types (comma separated)
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# ============================================
# MLM/REFERRAL SETTINGS
# ============================================
# Commission percentages by level
COMMISSION_LEVEL_1=10
COMMISSION_LEVEL_2=5
COMMISSION_LEVEL_3=3
COMMISSION_LEVEL_4=2
COMMISSION_LEVEL_5=1

# Minimum payout amount
MIN_PAYOUT_AMOUNT=500

# Currency
CURRENCY=INR
CURRENCY_SYMBOL=₹

# ============================================
# NOTIFICATION SETTINGS
# ============================================
# Enable/disable notifications
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false

# Notification cooldown (in minutes)
NOTIFICATION_COOLDOWN=60

# ============================================
# LOGGING SETTINGS
# ============================================
LOG_LEVEL=error
LOG_PATH=/var/www/apsdreamhome/logs
MAX_LOG_SIZE=10M
LOG_RETENTION_DAYS=30

# ============================================
# MAINTENANCE MODE
# ============================================
# Set to true to enable maintenance mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="We are performing scheduled maintenance. Please check back soon."

# Allowed IPs during maintenance (comma separated)
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================

# Google Analytics (optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Google reCAPTCHA (for forms)
RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# Google Maps API (for property locations)
GOOGLE_MAPS_API_KEY=your_maps_api_key

# Facebook Pixel (optional)
FACEBOOK_PIXEL_ID=XXXXXXXXXX

# ============================================
# DEVELOPMENT SETTINGS (DO NOT USE IN PRODUCTION)
# ============================================
# APP_DEBUG=true
# APP_ENV=development
# LOG_LEVEL=debug
