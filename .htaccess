<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Protect sensitive files
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^database/.*$ - [F,L]

    # Specific redirect for publiccontact to contact page
    RewriteRule ^publiccontact$ /apsdreamhome/public/contact [R=301,L]
    
    # Handle root path
    RewriteRule ^$ public/index.php?url= [L,QSA]

    # Redirect to public folder, but allow access to public assets
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php?url=$1 [L,QSA]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Disable directory indexing
Options -Indexes

# Protect .htaccess
<Files .htaccess>
    Order Allow,Deny
    Deny from all
</Files>