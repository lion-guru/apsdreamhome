# APS Dream Home - MCP Environment Configuration
# Database and Project API Keys Configuration

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=apsdreamhome

# ===========================================
# PROJECT PATHS
# ===========================================
APS_ROOT=C:\xampp\htdocs\apsdreamhome
APS_CONFIG=C:\xampp\htdocs\apsdreamhome\config
APS_STORAGE=C:\xampp\htdocs\apsdreamhome\storage
APS_PUBLIC=C:\xampp\htdocs\apsdreamhome\public

# ===========================================
# PROJECT METADATA
# ===========================================
PROJECT_NAME=APS Dream Home
PROJECT_TYPE=Real Estate CRM
PROJECT_VERSION=2.0.0
PROJECT_STATUS=production_ready

# ===========================================
# DATABASE STATISTICS
# ===========================================
DATABASE_TABLES=635
CONTROLLER_FILES=178
SERVICE_FILES=320
MODEL_FILES=145
VIEW_FILES=354

# ===========================================
# AI FEATURES CONFIGURATION
# ===========================================
AI_ENGINE=PropertyValuationEngine
AI_FEATURES=valuation,market_analysis,recommendations
AI_PATH=C:\xampp\htdocs\apsdreamhome\app\Services\AI
AI_API_ENDPOINT=http://localhost/apsdreamhome/api/ai/valuation

# ===========================================
# WEB SERVER CONFIGURATION
# ===========================================
BASE_URL=http://localhost/apsdreamhome
ADMIN_URL=http://localhost/apsdreamhome/admin
AI_VALUATION_URL=http://localhost/apsdreamhome/ai/property-valuation
PROJECT_API_BASE=http://localhost/apsdreamhome/api

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
API_KEY_REQUIRED=false
API_KEYS=aps2024-ai-key-1,aps2024-ai-key-2
CSRF_TOKEN_ENABLED=true
SESSION_ENCRYPTION=true

# ===========================================
# ANALYTICS CONFIGURATION
# ===========================================
ANALYTICS_TYPE=real_estate
DATA_PATH=C:\xampp\htdocs\apsdreamhome\storage\analytics
MEMORY_TYPE=project_context

# ===========================================
# SQLITE CONFIGURATION
# ===========================================
DB_PATH=C:\xampp\htdocs\apsdreamhome\storage\database\project_memory.sqlite
MEMORY_DATABASE=project_memory.sqlite

# ===========================================
# CONFIGURATION FILES
# ===========================================
CONFIG_PATH=C:\xampp\htdocs\apsdreamhome\config
DATABASE_CONFIG=database.php
APP_CONFIG=app.php
ROUTES_CONFIG=web.php

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
DEBUG_MODE=true
ERROR_LOGGING=true
PERFORMANCE_MONITORING=true
CACHE_ENABLED=true

# ===========================================
# MCP SERVER DESCRIPTIONS
# ===========================================
MCP_MYSQL_DESC=APS Dream Home Database Server - 635 tables with real estate data
MCP_FILESYSTEM_DESC=APS Dream Home File System - Complete project structure access
MCP_MEMORY_DESC=APS Dream Home Memory Server - Project context and AI features
MCP_SQLITE_DESC=APS Dream Home SQLite - Local project memory and caching
MCP_PUPPETEER_DESC=APS Dream Home Puppeteer - Web automation and testing
MCP_FETCH_DESC=APS Dream Home Fetch - API integration and external services
MCP_ANALYTICS_DESC=APS Dream Home Analytics - Property data and market analysis
MCP_AI_SERVICES_DESC=APS Dream Home AI Services - Property valuation and market analysis
MCP_CONFIG_DESC=APS Dream Home Configuration - Database and application settings

# ===========================================
# EXTERNAL API CONFIGURATION (if needed)
# ===========================================
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# PROPERTY_API_KEY=your_property_data_api_key
# MARKET_DATA_API_KEY=your_market_data_api_key
# WEATHER_API_KEY=your_weather_api_key

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
BACKUP_PATH=C:\xampp\htdocs\apsdreamhome\storage\backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily

# ===========================================
# POSTMAN API CONFIGURATION
# ===========================================
POSTMAN_COLLECTION=apsdreamhome-api
API_DOCUMENTATION=http://localhost/apsdreamhome/api/docs
AUTH_TYPE=session_based
RATE_LIMIT=1000_per_hour
API_VERSION=v1.0.0

# ===========================================
# MCP PLAYWRIGHT CONFIGURATION
# ===========================================
PLAYWRIGHT_MODE=automation_testing
CRAWLER_DEPTH=3
SCREENSHOT_PATH=C:\xampp\htdocs\apsdreamhome\storage\screenshots
BROWSER_HEADLESS=false
PAGE_TIMEOUT=30000

# ===========================================
# MCP SEQUENTIAL THINKING CONFIGURATION
# ===========================================
THINKING_MODE=sequential
MEMORY_DEPTH=deep
CONTEXT_WINDOW=large
AI_REASONING=step_by_step
THINKING_STEPS_ENABLED=true

# ===========================================
# ADVANCED MCP CONFIGURATION
# ===========================================
MCP_SERVER_COUNT=11
MCP_AUTO_START=true
MCP_LOG_LEVEL=info
MCP_CACHE_ENABLED=true
MCP_PERSISTENT_SESSION=true

# ===========================================
# API KEYS AND SECURITY
# ===========================================
# Main API Keys (for external services)
MAIN_API_KEY=aps2024-ai-main-key-secure
SECONDARY_API_KEY=aps2024-ai-secondary-key-secure
BACKUP_API_KEY=aps2024-ai-backup-key-secure

# Database API Keys
DATABASE_API_KEY=aps2024-db-key-secure
MYSQL_API_TOKEN=aps2024-mysql-token-secure

# AI Service API Keys
AI_VALUATION_API_KEY=
AI_ANALYTICS_API_KEY=
AI_RECOMMENDATIONS_API_KEY=aps2024-ai-recommendations-key-secure

# Security Configuration
API_ENCRYPTION_ENABLED=true
API_SIGNATURE_REQUIRED=true
API_RATE_LIMITING=true
API_CORS_ENABLED=true

# ===========================================
# MCP SERVER ENDPOINTS
# ===========================================
MCP_MYSQL_ENDPOINT=localhost:3307
MCP_FILESYSTEM_ENDPOINT=C:\xampp\htdocs\apsdreamhome
MCP_MEMORY_ENDPOINT=memory://apsdreamhome
MCP_SQLITE_ENDPOINT=C:\xampp\htdocs\apsdreamhome\storage\database\project_memory.sqlite
MCP_PUPPETEER_ENDPOINT=http://localhost:80
MCP_FETCH_ENDPOINT=http://localhost/apsdreamhome/api
MCP_ANALYTICS_ENDPOINT=C:\xampp\htdocs\apsdreamhome\storage\analytics
MCP_AI_SERVICES_ENDPOINT=C:\xampp\htdocs\apsdreamhome\app\Services\AI
MCP_CONFIG_ENDPOINT=C:\xampp\htdocs\apsdreamhome\config

# ===========================================
# POSTMAN COLLECTION EXPORT URLS
# ===========================================
POSTMAN_PROPERTY_API=http://localhost/apsdreamhome/api/properties
POSTMAN_AI_VALUATION_API=http://localhost/apsdreamhome/api/ai/valuation
POSTMAN_USER_API=http://localhost/apsdreamhome/api/users
POSTMAN_LEAD_API=http://localhost/apsdreamhome/api/leads
POSTMAN_COMMISSION_API=http://localhost/apsdreamhome/api/commissions
POSTMAN_PAYMENT_API=http://localhost/apsdreamhome/api/payments
POSTMAN_ADMIN_API=http://localhost/apsdreamhome/api/admin

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
MONITORING_ENABLED=true
MONITORING_PATH=C:\xampp\htdocs\apsdreamhome\storage\monitoring
LOG_PATH=C:\xampp\htdocs\apsdreamhome\logs
