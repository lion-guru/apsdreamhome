{
  "performance": {
    "maxConcurrentOperations": 5,
    "debounceDelay": 300,
    "autoSaveDelay": 1000,
    "memoryLimit": "2048MB",
    "cacheSize": "512MB"
  },
  "stability": {
    "restartOnError": true,
    "maxRetries": 3,
    "timeoutMs": 30000,
    "healthCheckInterval": 60000
  },
  "mcpOptimization": {
    "connectionPoolSize": 3,
    "requestTimeout": 15000,
    "keepAlive": true,
    "maxPayloadSize": "10MB"
  },
  "fileSystem": {
    "watcherDelay": 500,
    "ignorePatterns": [
      "node_modules/**",
      "vendor/**",
      ".git/**",
      "storage/logs/**",
      "*.tmp",
      "*.log"
    ]
  },
  "ui": {
    "disableAnimations": false,
    "maxFileSizeWarning": "50MB",
    "showPerformanceMetrics": true
  }
}
