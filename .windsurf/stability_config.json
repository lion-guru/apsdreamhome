{
  "errorHandling": {
    "autoRecover": true,
    "createBackupOnCrash": true,
    "logLevel": "warn",
    "maxLogFileSize": "100MB"
  },
  "memoryManagement": {
    "garbageCollectionInterval": 30000,
    "maxMemoryUsage": "70%",
    "forceGCOnHighMemory": true
  },
  "processManagement": {
    "maxProcessTime": 120000,
    "killHungProcesses": true,
    "heartbeatInterval": 30000
  },
  "resourceLimits": {
    "maxOpenFiles": 1000,
    "maxNetworkConnections": 50,
    "maxConcurrentRequests": 20
  },
  "healthChecks": {
    "enableSystemHealth": true,
    "checkInterval": 60000,
    "alertOnHighCPU": true,
    "alertOnHighMemory": true
  }
}
