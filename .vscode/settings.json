{
    "php.version": "8.4",
    "explorer.excludeGitIgnore": true,

    "// APS Dream Home - Memory Optimization Settings": "",
    "intelephense.maxMemory": 1024,
    "typescript.tsserver.maxTsServerMemory": 1024,
    "intelephense.completion.maxItems": 200,

    "// APS Dream Home - Intelephense Configuration": "",
    "intelephense.diagnostics.undefinedMethods": false,
    "intelephense.diagnostics.undefinedFunctions": false,
    "intelephense.diagnostics.undefinedConstants": false,
    "intelephense.diagnostics.undefinedClassConstants": false,
    "intelephense.diagnostics.undefinedProperties": false,
    "intelephense.diagnostics.undefinedTypes": false,
    "intelephense.diagnostics.duplicateSymbols": true,

    "// APS Dream Home - File Exclusions for Performance": "",
    "files.watcherExclude": {
        "**/node_modules/*/**": true,
        "**/vendor/*/**": true,
        "**/logs/*/**": true,
        "**/storage/*/**": true,
        "**/cache/*/**": true,
        "**/backup/*/**": true,
        "**/.git/*/**": true,
        "**/_DEPRECATED/*/**": true
    },
    "files.exclude": {
        "**/node_modules": true,
        "**/vendor": true,
        "**/logs": true,
        "**/storage/cache": true,
        "**/backup": true,
        "**/_DEPRECATED": true
    },
    "search.exclude": {
        "**/_DEPRECATED": true,
        "**/.git": true,
        "**/backup": true,
        "**/bin": true,
        "**/logs": true,
        "**/node_modules": true,
        "**/storage/cache": true,
        "**/vendor": true
    },

    "// APS Dream Home - PHP Configuration": "",
    "php.validate.enable": true,
    "php.validate.run": "onSave",
    "intelephense.environment.phpVersion": "8.2.0",

    "// APS Dream Home - Editor Configuration": "",
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "files.autoSave": "afterDelay",
    "workbench.editor.showTabIndex": true,
    "editor.wordWrap": "on",
    "editor.minimap.enabled": false,
    "editor.glyphMargin": false,
    "editor.folding": true,
    "editor.lineNumbers": "on",
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,

    "// APS Dream Home - Performance Settings": "",
    "editor.experimentalGpuAcceleration": "on",
    "editor.experimental.preferTreeSitter.css": false,
    "editor.experimental.preferTreeSitter.ini": false,
    "editor.experimental.preferTreeSitter.regex": false,
    "editor.experimental.preferTreeSitter.typescript": false,
    "typescript.disableAutomaticTypeAcquisition": true,
    "typescript.enablePromptUseWorkspaceTsdk": false,
    "files.autoSaveDelay": 1000,
    "workbench.enableExperiments": false,
    "telemetry.enableTelemetry": false,
    "extensions.autoUpdate": false,
    "extensions.autoCheckUpdates": false,
    "update.mode": "none",
    "extensions.ignoreRecommendations": true,
    "workbench.startupEditor": "none",
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "git.confirmSync": false,

    "// APS Dream Home - Language Specific": "",
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    "// APS Dream Home - Database Configuration": "",
    "sqltools.connections": [
        {
            "previewLimit": 50,
            "server": "localhost",
            "port": 3306,
            "driver": "MySQL",
            "name": "APS Dream Home",
            "database": "apsdreamhome",
            "username": "root",
            "password": ""
        }
    ],

    "// APS Dream Home - Disable Unused Features": "",
    "markdown.validate.enabled": false,
    "css.format.spaceAroundSelectorSeparator": false,
    "scss.format.spaceAroundSelectorSeparator": false,
    "powershell.codeFormatting.trimWhitespaceAroundPipe": false,
    "javascript.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": false,
    "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": false,
    "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyParenthesis": false,
    "javascript.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": false,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": false,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": false,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyParenthesis": false,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": false,

    "// APS Dream Home - Disable AI Features for Performance": "",
    "codium.codeCompletion.enable": false,
    "editor.aiStats.enabled": false,
    "dbcode.ai.mcp.autoStart": false,
    "chat.agent.maxRequests": 50,

    "// APS Dream Home - Disable Testing Features": "",
    "testing.automaticallyOpenPeekViewDuringAutoRun": false,
    "notebook.formatOnSave.enabled": true,
    "notebook.defaultFormatter": "esbenp.prettier-vscode",

    "// APS Dream Home - Disable Advanced Features": "",
    "advancedPhpCsFixer.allowRisky": false,
    "intelephense.completion.fullyQualifyGlobalConstantsAndFunctions": false,
    "intelephense.compatibility.preferPsalmPhpstanPrefixedAnnotations": false,
    "intelephense.codeLens.usages.enable": false,
    "intelephense.codeLens.references.enable": false,
    "intelephense.codeLens.parent.enable": false,
    "intelephense.codeLens.overrides.enable": false,
    "intelephense.codeLens.implementations.enable": false,
    "intelephense.phpdoc.useFullyQualifiedNames": false,
    "editor.linkedEditing": true,
    "gemini-cli.debug.logging.enabled": true,
    "geminicodeassist.agentDebugMode": true,
    "geminicodeassist.agentYoloMode": true,
    "geminicodeassist.codeGenerationPaneViewEnabled": true,
    "geminicodeassist.inlineSuggestions.nextEditPredictions": true,
    "geminicodeassist.outlines.automaticOutlineGeneration": true,
    "geminicodeassist.verboseLogging": true,
    "intelephense.rename.namespaceMode": "all",
    "intelephense.trace.server": "verbose",
    "eslint.format.enable": true,
    "notebook.formatOnCellExecution": true,
    "editor.formatOnPaste": true,
    "prettier.useEditorConfig": false,
    "prettier.configPath": ".prettierrc",
    "prettier.ignorePath": ".prettierignore",
    "prettier.requireConfig": true,
    "editor.experimental.asyncTokenizationLogging": true,
    "editor.experimental.asyncTokenizationVerification": true
}
