{
    // APS Dream Home - PHP Debug Configuration
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch APS Dream Home (Built-in Server)",
            "type": "php",
            "request": "launch",
            "runtimeArgs": [
                "-S",
                "localhost:8080",
                "-t",
                "public"
            ],
            "cwd": "${workspaceFolder}/public",
            "port": 9003,
            "serverReadyAction": {
                "pattern": "Development Server \\(http://localhost:([0-9]+)\\) started",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        },
        {
            "name": "Listen for Xdebug (APS Dream Home)",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/server": "${workspaceFolder}"
            }
        },
        {
            "name": "Launch Currently Open Script",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.start_with_request=yes"
            ],
            "env": {
                "XDEBUG_MODE": "debug,develop",
                "XDEBUG_CONFIG": "client_port=${port}"
            }
        },
        {
            "name": "Debug APS Dream Home with Xdebug",
            "type": "php",
            "request": "launch",
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes",
                "-S",
                "localhost:8080",
                "-t",
                "public"
            ],
            "cwd": "${workspaceFolder}/public",
            "port": 9003,
            "serverReadyAction": {
                "action": "openExternally"
            }
        },
        {
            "type": "vscode-edge-devtools.debug",
            "request": "attach",
            "name": "Attach to Microsoft Edge",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}/public"
        },
        {
            "type": "firefox",
            "request": "launch",
            "reAttach": true,
            "name": "Launch Firefox Debug",
            "file": "${workspaceFolder}/public/index.html"
        }
    ]
}
