                    {
                        "key": "Content-Type",
                        "value": "application\/json"
                    },
                    {
                        "key": "Accept",
                        "value": "application\/json"
                    }
                ],
                "url": {
                    "raw": "{{BASE_URL}}\/api{{API_VERSION}}\/auth\/login",
                    "host": [
                        "{{BASE_URL}}"
                    ],
                    "path": [
