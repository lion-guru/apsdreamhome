#!/usr/bin/env bash
# APS Dream Home - Git Post-merge Hook
# Runs route health check after merge

echo "🔄 Running post-merge checks..."

# Check if this was a merge (not just a regular commit)
if [ -f .git/MERGE_HEAD ]; then
    echo "📋 Merge detected, running route health check..."

    # Run route health check if it exists
    if [ -f "tests/diagnostics/route_health_check.php" ]; then
        php tests/diagnostics/route_health_check.php > /dev/null 2>&1
        if [ $? -eq 0 ]; then
            echo "✅ Route health check passed"
        else
            echo "⚠️ Route health check failed - check logs"
        fi
    else
        echo "ℹ️ Route health check script not found"
    fi
else
    echo "📝 Regular commit detected, skipping merge checks"
fi

echo "✅ Post-merge checks complete"
