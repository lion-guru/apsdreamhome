#!/usr/bin/env bash
# APS Dream Home - Git Pre-commit Hook
# Runs PHP syntax check on changed .php files

echo "🔍 Running PHP syntax check..."

# Get list of changed PHP files
changed_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$')

if [ -z "$changed_files" ]; then
    echo "✅ No PHP files changed"
    exit 0
fi

# Check PHP syntax for each changed file
error_found=0
for file in $changed_files; do
    if [ -f "$file" ]; then
        echo "Checking $file..."
        # Capture both stdout and stderr
        output=$(php -l "$file" 2>&1)
        exit_code=$?

        # Check if there are actual syntax errors (exclude DLL warnings)
        if [ $exit_code -ne 0 ]; then
            # Filter out DLL compatibility warnings
            syntax_errors=$(echo "$output" | grep -v "VCRUNTIME140.dll" | grep -v "is not compatible with this PHP build")

            if [ -n "$syntax_errors" ]; then
                echo "❌ Syntax error in $file"
                echo "$output"
                error_found=1
            else
                echo "✅ $file OK (DLL warning ignored)"
            fi
        else
            echo "✅ $file OK"
        fi
    fi
done

if [ $error_found -eq 1 ]; then
    echo "❌ Commit blocked due to PHP syntax errors"
    exit 1
fi

echo "✅ All PHP files passed syntax check"
exit 0
